NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Required for PayPal checkout, admin "Create user" (POST /api/admin/users), and calendar blocking. Never expose in the browser.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: public site URL for auth invite redirects (defaults to VERCEL_URL or http://localhost:3000)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# PayPal (Orders v2). Sandbox API: https://api-m.sandbox.paypal.com — Live: https://api-m.paypal.com
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_CLIENT_SECRET=your_paypal_secret
# Optional: same as public ID if you only set one in the dashboard
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
# Webhook signature verification (Dashboard → Webhooks → Webhook ID)
# PAYPAL_WEBHOOK_ID=your_webhook_id
#
# Handoff checklist (never commit real values): copy this file to .env.local for next dev;
# paste the same keys into Vercel → Project → Environment Variables (Preview + Production).
# Use PayPal Sandbox first; switch Production to live keys and PAYPAL_API_BASE=https://api-m.paypal.com when ready.

# Optional: paste URI from Dashboard → Connect (Transaction pooler is fine; IPv4-friendly). For scripts/apply-harare-usd-to-db.mjs
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# Or build pooler URL without DATABASE_URL:
# SUPABASE_DB_PASSWORD=...
# SUPABASE_POOLER_REGION=us-east-1
# SUPABASE_POOLER_MODE=transaction
